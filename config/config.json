{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "react-under-standing-webpart-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/reactUnderStandingWebpart/ReactUnderStandingWebpartWebPart.js",
          "manifest": "./src/webparts/reactUnderStandingWebpart/ReactUnderStandingWebpartWebPart.manifest.json"
        }
      ]
    },
    "share-pointform-web-part": {
      "components": [
        {
