  },
  "externals": {},
  "localizedResources": {
    "ReactUnderStandingWebpartWebPartStrings": "lib/webparts/reactUnderStandingWebpart/loc/{locale}.js",
    "SharePointformWebPartStrings": "lib/webparts/sharePointform/loc/{locale}.js"
  }
